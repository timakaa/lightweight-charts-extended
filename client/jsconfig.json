{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@hooks/*": ["./src/hooks/*"],
      "@components/*": ["./src/components/*"],
      "@icons/*": ["./src/icons/*"],
      "@store/*": ["./src/store/*"],
      "@helpers/*": ["./src/helpers/*"],
      "@drawing-tools/*": ["./src/drawing-tools/*"],
      "@config/*": ["./src/config/*"],
      "@pages/*": ["./src/pages/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
